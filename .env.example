# Copy this file to .env and put real values in it.
# .env is ignored by git and must never be committed.
#   cp .env.example .env

# Password for the Postgres container.
POSTGRES_PASSWORD=postgres

# Signing key for JWT. Must be at least 32 characters,
# otherwise the app fails to start (WeakKeyException).
JWT_SECRET=replace_this_with_a_long_random_string_min_32_chars

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=replace_with_your_key